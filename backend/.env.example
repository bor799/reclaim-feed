# ============================================
# 100X 知识萃取系统 - 环境变量配置示例
# ============================================
# 使用方法: 复制此文件为 .env 并填入真实的配置值

# --------------------------------------------
# AI Provider API Keys
# --------------------------------------------
# 智谱 AI API Key (GLM-4 模型)
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI API Key (可选，用于 GPT-4 等模型)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (可选，用于 Claude 模型)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API Key (可选)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --------------------------------------------
# 系统配置
# --------------------------------------------
# 是否启用认证 (生产环境建议启用)
AUTH_ENABLED=False

# 时区设置
TZ=Asia/Shanghai

# --------------------------------------------
# 网络代理 (可选，用于访问国际 API)
# --------------------------------------------
# HTTP/HTTPS 代理地址
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# --------------------------------------------
# Telegram Bot 配置 (可选)
# --------------------------------------------
# Telegram Bot Token (用于推送萃取结果)
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (推送目标)
# TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram 代理地址 (如果需要)
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890

# --------------------------------------------
# 飞书机器人配置 (可选)
# --------------------------------------------
# 飞书 Webhook URL
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_url

# --------------------------------------------
# 数据库配置 (可选，默认使用 SQLite)
# --------------------------------------------
# DATABASE_URL=sqlite:///./knowledge_agent.db
