# ============================================
# 100X 知识萃取系统 - 前端环境变量配置示例
# ============================================
# 使用方法: 复制此文件为 .env.local 并填入真实的配置值

# --------------------------------------------
# 后端 API 地址
# --------------------------------------------
# 本地开发环境
VITE_API_BASE_URL=http://localhost:8000

# 生产环境（部署时修改为实际的后端地址）
# VITE_API_BASE_URL=https://your-backend-domain.com

# --------------------------------------------
# 其他配置（可选）
# --------------------------------------------
# 应用标题
# VITE_APP_TITLE=100X 知识萃取系统

# 启用调试模式
# VITE_DEBUG=true
