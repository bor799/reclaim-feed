# ============================================
# 100X 知识萃取系统 - 前端生产环境配置示例
# ============================================

# --------------------------------------------
# API 地址配置
# --------------------------------------------
# 生产环境: 使用相对路径 (前后端部署在同一域名下)
VITE_API_BASE_URL=/

# 开发环境: 使用完整的后端地址
# VITE_API_BASE_URL=http://localhost:8000

# Docker 环境: 如果前后端不在同一容器
# VITE_API_BASE_URL=http://backend:8000

# --------------------------------------------
# 其他配置 (可选)
# --------------------------------------------
# 应用标题
# VITE_APP_TITLE=100X 知识萃取系统

# 是否启用调试模式
# VITE_DEBUG=false
